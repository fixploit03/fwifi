# Check if script is run as root
if [ "$EUID" -ne 0 ]; then
  echo "[Error] This script must be run as root."
  exit 1
fi

# Default network interface
interface=""

# Parse command-line options
while getopts "i:-:" opt; do
  case $opt in
    i)
      # Specify the network interface
      interface="$OPTARG"
      ;;
    -)
      case "${OPTARG}" in
        interface)
          # Extended option to specify the network interface
          interface="${!OPTIND}"
          OPTIND=$((OPTIND + 1))
          ;;
        *)
          echo "[Error] Invalid option: --${OPTARG}"
          exit 1
          ;;
      esac
      ;;
    \?)
      echo "[Error] Invalid option: -$OPTARG"
      exit 1
      ;;
  esac
done

# Check if a network interface is specified
if [ -z "$interface" ]; then
  echo "[Error] Interface is not specified. Please use the -i or --interface option."
  exit 1
fi

# Check if the specified network interface exists
if ! ip link show "$interface" &>/dev/null; then
  echo "[Error] Interface '$interface' not found."
  exit 1
fi

# Clear the terminal screen
clear

type_effect() {
    text="$1"
    delay="$2"

    for ((i = 0; i < ${#text}; i++)); do
        echo -n "${text:$i:1}"
        sleep "$delay"
    done
    echo ""
}

