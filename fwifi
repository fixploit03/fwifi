if [ "$EUID" -ne 0 ]; then
  echo "[Error] This script must be run as root."
  exit 1
fi

# Default interface
interface=""

while getopts "i:-:" opt; do
  case $opt in
    i)
      interface="$OPTARG"
      ;;
    -)
      case "${OPTARG}" in
        interface)
          interface="${!OPTIND}"
          OPTIND=$((OPTIND + 1))
          ;;
        *)
          echo "[Error] Invalid option: --${OPTARG}"
          exit 1
          ;;
      esac
      ;;
    \?)
      echo "[Error] Invalid option: -$OPTARG"
      exit 1
      ;;
  esac
done

if [ -z "$interface" ]; then
  echo "[Error] Interface is not specified. Please use the -i or --interface option."
  exit 1
fi

if ! ip link show "$interface" &>/dev/null; then
  echo "[Error] Interface '$interface' not found."
  exit 1
fi

while true; do
  clear
  echo ""
  echo "    @@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@"
  echo "      _______      ________      _______      _______      _______  "
  echo "     |    ___|    |  |  |  |    |_     _|    |    ___|    |_     _| "
  echo "     |    ___|    |  |  |  |     _|   |_     |    ___|     _|   |_  "
  echo "     |___|        |________|    |_______|    |___|        |_______| "
  echo "                                                                    "
  echo "              Github: https://github.com/rofidoang03/fwifi          "
  echo "                                                                    "
  echo "     @@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@ "
  echo "                                                                    "
  echo "     [0] Update                                                     "
  echo "     [1] Enable Monitor Mode (airmon-ng)                            "
  echo "     [2] Disable Monitor Mode (airmon-ng)                           "
  echo "     [3] Capture Wi-Fi Data (airodump-ng)                           "
  echo "     [4] Capture Wi-Fi Data (besside-ng)                            "
  echo "     [5] Inject Wi-Fi Packets (aireplay-ng)                         "
  echo "     [6] Check for valid 4-way frames (cowpatty)                    "
  echo "     [7] Crack Wi-Fi Key (aircrack-ng)                              "
  echo "     [8] Crack Wi-Fi Key (cowpatty)                                 "
  echo "    [99] Exit                                                       "
  echo "                                                                    "
  # Prompt user input
  read -p "[fwifi] " choice

  case $choice in
    0)
      # Update
      apt-get update -y
      echo ""
      read -p "[Info] Press [Enter] to continue..."
      ;;
    1)
      # Enable Monitor Mode
      airmon-ng check kill
      airmon-ng start "${interface}"
      echo ""
      read -p "[Info] Press [Enter] to continue..."
      ;;
    2)
      # Disable Monitor Mode
      airmon-ng stop "${interface}"
      echo ""
      read -p "[Info] Press [Enter] to continue..."
      ;;
    3)
      # Capture Wi-Fi Data
      airodump-ng "${interface}"
      echo ""
      read -p "[fwifi] Enter the MAC Address of the Access Point: " target_bssid

      while [[ ! "${target_bssid}" =~ ^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$ ]]; do
          echo "[Error] Invalid BSSID format. Please enter a valid MAC address (e.g., XX:XX:XX:XX:XX:XX)."
          read -p "[fwifi] Enter the MAC Address of the Access Point: " target_bssid
      done

      read -p "[fwifi] Enter the channel: " channel

      while [[ ! "$channel" =~ ^[0-9]+$ ]]; do
          echo "[Error] Invalid channel. Please enter a valid numeric channel."
          read -p "[fwifi] Enter the channel: " channel
      done

      read -p "[fwifi] Enter the output file name: " output_file
      airodump-ng --bssid "${target_bssid}" --channel "${channel}" -w "${output_file}" "${interface}"
      echo ""
      read -p "[Info] Press [Enter] to continue..."
      ;;
    4)
      # Capture Wi-Fi Data (besside-ng)
      airodump-ng "${interface}"
      echo ""
      read -p "[fwifi] Enter the MAC Address of the Access Point: " target_bssid

      while [[ ! "${target_bssid}" =~ ^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$ ]]; do
          echo "[Error] Invalid BSSID format. Please enter a valid MAC address (e.g., XX:XX:XX:XX:XX:XX)."
          read -p "[fwifi] Enter the MAC Address of the Access Point: " target_bssid
      done

      read -p "[fwifi] Enter the channel: " channel

      while [[ ! "$channel" =~ ^[0-9]+$ ]]; do
          echo "[Error] Invalid channel. Please enter a valid numeric channel."
          read -p "[fwifi] Enter the channel: " channel
      done

      besside-ng -b "${target_bssid}" -c "${channel}" -W -vv "${interface}"
      echo ""
      read -p "[Info] Press [Enter] to continue..."
      ;;
    5)
      # Inject Wi-Fi Packets
      read -p "[fwifi] Enter the MAC Address of the Access Point: " ap

      while [[ ! "${ap}" =~ ^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$ ]]; do
          echo "[Error] Invalid BSSID format. Please enter a valid MAC address (e.g., XX:XX:XX:XX:XX:XX)."
          read -p "[fwifi] Enter the MAC Address of the Access Point: " ap
      done


      aireplay-ng -0 0 -a "${ap}" "${interface}"
      echo ""
      read -p "[Info] Press [Enter] to continue..."
      ;;
    6)
      # Check for valid 4-way frames
      read -p "[fwifi] Enter the handshake file name: " file_handshake

      while [[ ! -f "${file_handshake}" ]]; do
          echo "[Error] Handshake file '${file_handshake}' not found."
          read -p "[fwifi] Enter the handshake file name: " file_handshake
      done

      cowpatty -c -r "${file_handshake}"
      read -p "[Info] Press [Enter] to continue..."
      ;;
    7)
      # Crack Wi-Fi Key
      read -p "[fwifi] Enter the handshake file name: " file_handshake

      while [[ ! -f "${file_handshake}" ]]; do
          echo "[Error] Handshake file '${file_handshake}' not found."
          read -p "[fwifi] Enter the handshake file name: " file_handshake
      done

      read -p "[fwifi] Enter the wordlist file name: " file_wordlist

      while [[ ! -f "${file_wordlist}" ]]; do
          echo "[Error] Wordlist file '${file_wordlist}' not found."
          read -p "[fwifi] Enter the wordlist file name: " file_wordlist
      done

      aircrack-ng -a2 -w "${file_wordlist}" "$file_handshake"
      echo ""
      read -p "[Info] Press [Enter] to continue..."
      ;;
    8)
      # Crack Wi-Fi Key cowpatty
      read -p "[fwifi] Enter the Network SSID (enclose in quotes if SSID includes spaces): " ssid

      while [[ -z "${ssid}" ]]; do
          echo "[Error] SSID Network cannot be empty."
          read -p "[fwifi] Enter the Network SSID (enclose in quotes if SSID includes spaces): " ssid
      done

      read -p "[fwifi] Enter the handshake file name: " file_handshake

      while [[ ! -f "${file_handshake}" ]]; do
          echo "[Error] Handshake file '${file_handshake}' not found."
          read -p "[fwifi] Enter the handshake file name: " file_handshake
      done

      read -p "[fwifi] Enter the wordlist file name : " file_wordlist

      while [[ ! -f "${file_wordlist}" ]]; do
          echo "[Error] Wordlist file '${file_wordlist}' not found."
          read -p "[fwifi] Enter the wordlist file name: " file_wordlist
      done

      cowpatty -f "${file_wordlist}" -r "${file_handshake}" -s "${ssid}" -v
      echo ""
      read -p "[Info] Press [Enter] to continue..."
      ;;
    99)
      # Exit
      echo "Thank you! Exiting the program."
      exit 0
      ;;
    ls)
      echo ""
      ls
      echo ""
      read -p "[Info] Press [Enter] to continue..."
      ;;
    *)
      # Invalid choice
      echo "[Error] Invalid choice. Please choose again."
      ;;
  esac
done
